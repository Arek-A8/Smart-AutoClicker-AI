<!--
  Cleartext HTTP is blocked by default on Android 9+. The local AI vision backend talks to a llama.cpp
  server on the loopback interface over plain HTTP, so we permit cleartext ONLY to localhost. All other
  destinations keep the secure default (HTTPS required).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
